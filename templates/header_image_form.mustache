{{!
    @template theme_solent/header_image_form

    Header image form template.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * options - Array of items
      * currentoption - The currently selected image
      * searchurl - The option id
      * id - The form option
      * options - Course id
      * course - Course id

    Example context (json):
    {
        "options": [
            {
                "currentoption": 1,
                "searchurl": "",
                "id": 1,
                "options": 1,
                "course": 1,
            }
        ]
    }
}}

<div>
	<p>Option {{currentoption}} is currently selected.</p>
	<p>Click the radio button next to an image to select it. You will then be redirected back to the previous page.</p>		


		<form action="{{searchurl}}" id="{{id}}" method="post">	
			<fieldset class="coursesearchbox invisiblefieldset">
				<table>
					{{{options}}}					
				</table>
				<input type="hidden" name="course" value="{{course}}"/>
				<input type="hidden" name="id" value="{{option}}"/>
			</fieldset>
		</form>
	
</div>

